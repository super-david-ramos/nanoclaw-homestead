{
  "name": "nanoclaw",
  "version": "2.0.13",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "bun run setup/index.ts",
    "setup:auto": "bun run setup/auto.ts",
    "chat": "bun run scripts/chat.ts",
    "auth": "bun run src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "bun test --isolate",
    "test:watch": "bun test --watch --isolate",
    "test:coverage": "bun test --isolate --coverage"
  },
  "dependencies": {
    "@chat-adapter/telegram": "4.26.0",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@onecli-sh/sdk": "^0.3.1",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.13"
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs",
    "sharp"
  ]
}
